{
  "manifest_version": 3,
  "name": "[CBA] Zillow Browser Agent",
  "description": "Real browser scraper agent for Zillow",
  "version": "1.0",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "storage",
    "alarms"
  ],
  "host_permissions": ["http://*/*", "https://*/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject_capture.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icons/icon.png"
  }
}
